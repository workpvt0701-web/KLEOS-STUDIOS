# =====================================================================
# KLEOS — backend environment variables
# Copy this file to ".env" (no .example) and fill in your real values.
# NEVER commit the real .env to GitHub — it holds your secrets.
# =====================================================================

# Your Gmail address (contact form sends to and from this)
EMAIL=youremail@gmail.com

# Gmail App Password (16 chars, NOT your normal password)
EMAIL_PASSWORD=your_app_password_here

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/kleos

# Password to log into the admin panel
ADMIN_PASSWORD=choose_a_strong_password

# Your live frontend URL (for CORS) e.g. https://yourname.github.io
FRONTEND_URL=https://YOUR-SITE-URL.com

# Port the server runs on (Render sets this automatically)
PORT=3000
